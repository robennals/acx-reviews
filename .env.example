# Turso (libSQL) — get from https://app.turso.tech
DATABASE_URL=libsql://your-db.turso.io
TURSO_TOKEN=

# Auth.js — generate AUTH_SECRET with `openssl rand -base64 32`
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Postmark — for sign-in PIN emails
POSTMARK_TOKEN=
POSTMARK_FROM=

# Comma-separated admin emails (lowercase)
ADMIN_EMAILS=

# Voting period config now lives in the committed data/voting-config.json
# (contestYear, contestTitle, votingStart, votingEnd). The contest is only
# shown/votable once an admin flips the launch switch in /admin (stored in
# the site_flags table). No voting-related env vars are needed.
