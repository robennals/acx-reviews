# Turso (libSQL) — get from https://app.turso.tech
DATABASE_URL=libsql://your-db.turso.io
TURSO_TOKEN=

# Auth.js — generate AUTH_SECRET with `openssl rand -base64 32`
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sign-in PIN email provider: "postmark" (default) or "resend".
# Only the selected provider's vars need to be set.
EMAIL_PROVIDER=postmark

# Postmark — for sign-in PIN emails
POSTMARK_TOKEN=
POSTMARK_FROM=

# Resend (https://resend.com) — alternative PIN email provider.
# RESEND_FROM must be on a domain verified in Resend.
RESEND_TOKEN=
RESEND_FROM=

# Comma-separated admin emails (lowercase)
ADMIN_EMAILS=

# Voting period config now lives in the committed data/voting-config.json
# (contestYear, contestTitle, votingStart, votingEnd). The contest is only
# shown/votable once an admin flips the launch switch in /admin (stored in
# the site_flags table). No voting-related env vars are needed.
#
# Optional: PREVIEW_CONTEST_LIVE=true hard-codes the contest as launched for a
# single deploy (e.g. a private preview), bypassing the DB flag. Never set in
# production.

# Results report (/results). Optional: set RESULT_CSV_PATH to a local vote-export
# CSV (header: voter_email,rating,review_title,review_slug,rated_at) to analyze
# that export instead of the votes DB. Leave unset on deploy to read live votes.
# RESULT_CSV_PATH=/absolute/path/to/votes-export.csv
