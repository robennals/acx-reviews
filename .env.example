# Turso (libSQL) — get from https://app.turso.tech
DATABASE_URL=libsql://your-db.turso.io
TURSO_TOKEN=

# Auth.js — generate AUTH_SECRET with `openssl rand -base64 32`
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Postmark — for sign-in PIN emails
POSTMARK_TOKEN=
POSTMARK_FROM=

# Comma-separated admin emails (lowercase)
ADMIN_EMAILS=

# Active voting period (optional). Set all four to enable voting.
# Dates are ISO 8601, inclusive of start, exclusive of end.
VOTING_CONTEST_YEAR=
VOTING_CONTEST_TITLE=
VOTING_START=
VOTING_END=
